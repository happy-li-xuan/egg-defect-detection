# YOLO 模型路径（绝对路径或相对 server/ 目录的路径）
EGG_MODEL_PATH=./models/best.pt

# 默认置信度阈值（0-1）
EGG_CONF=0.65

# Flask debug 模式
FLASK_DEBUG=true
